# Optional provider keys for local development.
VITE_GEMINI_API_KEY=""
VITE_OPENAI_API_KEY=""
VITE_ANTHROPIC_API_KEY=""

# WebSocket relay backend. Must end with ?code=
# Example with proxymid worker: wss://proxymid.<your-subdomain>.workers.dev/?code=
VITE_RELAY_WS_BASE="wss://proxymid.your-subdomain.workers.dev/?code="

# Relay web/publish base used in UI hints.
VITE_RELAY_WEB_BASE="https://proxymid.your-subdomain.workers.dev/"
